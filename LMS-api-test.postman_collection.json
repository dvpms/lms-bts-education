                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"nama_course\": \"Nama Kursus Diedit\",\n    \"deskripsi\": \"Deskripsi sudah diperbarui.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {

          }
        },
        {
          "name": "Logout User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Memeriksa status respons adalah 204 No Content",
                  "pm.test(\"Status code is 204\", function () {",
                  "    pm.response.to.have.status(204);",
                  "});",
                  "",
                  "// Clear access token dari environment",
                  "pm.test(\"Clear access token from environment\", function () {",
                  "    pm.environment.unset('accessToken');",
                  "    console.log('Access token cleared from environment');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "apikey",
                "value": "{{supabaseAnonKey}}"
              }
            ],
            "url": {
              "raw": "{{supabaseUrl}}/auth/v1/logout",
              "host": [
                "{{supabaseUrl}}"
              ],
              "path": [
                "auth",
                "v1",
                "logout"
              ]
            },
            "description": "Test logout functionality"
          }
        }
      ],
      "description": "Tests untuk authentication endpoints dan database operations"
    }
  ]
}

{
  "info": {
    "name": "LMS BTS Education API Tests",
    "description": "Collection untuk testing API Learning Management System BTS Education",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login with Email and Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Memeriksa status respons adalah 200 OK",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: Memeriksa respons dalam format JSON",
                  "pm.test(\"Response is JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "// Test 3: Memeriksa body respons berisi access_token dan user",
                  "pm.test(\"Response contains access_token and user\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('access_token');",
                  "    pm.expect(responseJson).to.have.property('user');",
                  "});",
                  "",
                  "// Test 4: Memeriksa access_token adalah string valid",
                  "pm.test(\"Access token is valid string\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.access_token).to.be.a('string');",
                  "    pm.expect(responseJson.access_token.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "// Test 5: Memeriksa user memiliki properti email",
                  "pm.test(\"User contains email\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.user).to.have.property('email');",
                  "    pm.expect(responseJson.user.email).to.be.a('string');",
                  "});",
                  "",
                  "// Simpan access_token ke environment variable",
                  "pm.test(\"Save access_token to environment\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.access_token) {",
                  "        pm.environment.set('accessToken', responseJson.access_token);",
                  "        console.log('Access token saved to environment:', responseJson.access_token.substring(0, 20) + '...');",
                  "    }",
                  "});",
                  "",
                  "// Test tambahan: Memeriksa tidak ada error",
                  "pm.test(\"No error in response\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.not.have.property('error');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "apikey",
                "value": "{{supabaseAnonKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{supabaseUrl}}/auth/v1/token?grant_type=password",
              "host": [
                "{{supabaseUrl}}"
              ],
              "path": [
                "auth",
                "v1",
                "token"
              ],
              "query": [
                {
                  "key": "grant_type",
                  "value": "password"
                }
              ]
            },
            "description": "Test login functionality menggunakan Supabase Auth API"
          }
        },
        {
          "name": "Get Current User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Memeriksa status respons adalah 200 OK",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test: Memeriksa respons berisi user data",
                  "pm.test(\"Response contains user data\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('id');",
                  "    pm.expect(responseJson).to.have.property('email');",
                  "});",
                  "",
                  "// Test: Memeriksa user authenticated",
                  "pm.test(\"User is authenticated\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.email).to.be.a('string');",
                  "    pm.expect(responseJson.id).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "apikey",
                "value": "{{supabaseAnonKey}}"
              }
            ],
            "url": {
              "raw": "{{supabaseUrl}}/auth/v1/user",
              "host": [
                "{{supabaseUrl}}"
              ],
              "path": [
                "auth",
                "v1",
                "user"
              ]
            },
            "description": "Test mendapatkan informasi user yang sedang login"
          }
        },
        {

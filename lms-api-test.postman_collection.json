    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login with Email and Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Memeriksa status respons adalah 200 OK",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: Memeriksa respons dalam format JSON",
                  "pm.test(\"Response is JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "// Test 3: Memeriksa body respons berisi data dengan access_token dan user",
                  "pm.test(\"Response contains access_token and user\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('data');",
                  "    pm.expect(responseJson.data).to.have.property('access_token');",
                  "    pm.expect(responseJson.data).to.have.property('user');",
                  "});",
                  "",
                  "// Test 4: Memeriksa access_token adalah string valid",
                  "pm.test(\"Access token is valid string\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.data.access_token).to.be.a('string');",
                  "    pm.expect(responseJson.data.access_token.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "// Test 5: Memeriksa user memiliki properti email",
                  "pm.test(\"User contains email\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.data.user).to.have.property('email');",
                  "    pm.expect(responseJson.data.user.email).to.be.a('string');",
                  "});",
                  "",
                  "// Simpan access_token ke environment variable",
                  "pm.test(\"Save access_token to environment\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.data && responseJson.data.access_token) {",
                  "        pm.environment.set('accessToken', responseJson.data.access_token);",
                  "        console.log('Access token saved to environment:', responseJson.data.access_token.substring(0, 20) + '...');",
                  "    }",
                  "});",
                  "",
                  "// Test tambahan: Memeriksa tidak ada error",
                  "pm.test(\"No error in response\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.not.have.property('error');",
                  "    pm.expect(responseJson).to.have.property('success', true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth", 
                "login"
              ]
            },
            "description": "Test login functionality menggunakan Supabase Auth API"
          }
        },
